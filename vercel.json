{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/summarize?refresh=true",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/summarize?refresh=true",
      "schedule": "0 7 * * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 300
    }
  }
}
